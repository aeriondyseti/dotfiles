#!/bin/bash
# Install core CLI tools — managed by chezmoi
set -euo pipefail

{{ if ne .profile "server" -}}
# ─────────────────────────────────────────
# Personal + Work: Homebrew (macOS native, Linuxbrew on Linux)
# ─────────────────────────────────────────
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    {{ if eq .chezmoi.os "darwin" -}}
    eval "$(/opt/homebrew/bin/brew shellenv zsh)"
    {{ else -}}
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
    {{ end -}}
fi

brew install \
    bat \
    btop \
    eza \
    fd \
    fzf \
    git \
    git-delta \
    gh \
    jq \
    lazydocker \
    lazygit \
    ripgrep \
    zoxide

# Claude Code (native binary)
if ! command -v claude &>/dev/null; then
    curl -fsSL https://claude.ai/install.sh | bash
fi

# Gemini CLI
if ! command -v gemini &>/dev/null; then
    npm install -g @google/gemini-cli
fi

{{ else -}}
# ─────────────────────────────────────────
# Server: apt only, minimal set
# ─────────────────────────────────────────
sudo apt update -y
sudo apt install -y \
    bat \
    fd-find \
    fzf \
    git \
    jq \
    ripgrep \
    zoxide

# bat and fd have different binary names on Debian/Ubuntu
if [ ! -L "$HOME/.local/bin/bat" ] && command -v batcat &>/dev/null; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(command -v batcat)" "$HOME/.local/bin/bat"
fi
if [ ! -L "$HOME/.local/bin/fd" ] && command -v fdfind &>/dev/null; then
    mkdir -p "$HOME/.local/bin"
    ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
fi
{{ end -}}

echo "Package installation complete."
