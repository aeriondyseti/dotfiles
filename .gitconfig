[alias]
	s = status
	d = diff
	l = log --oneline -n 20

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[pull]
	rebase = true

[credential "https://github.com"]
	helper = !/usr/bin/env gh auth git-credential

[credential "https://gist.github.com"]
	helper = !/usr/bin/env gh auth git-credential

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	light = false
	side-by-side = true

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
