# PowerShell profile — managed by chezmoi (Windows)
# Mirrors the zsh setup: source split-out config files if present.
# $PSScriptRoot is this profile's folder, so siblings resolve regardless of
# where Documents lives (handles OneDrive redirection).

if (Test-Path "$PSScriptRoot\env.ps1")       { . "$PSScriptRoot\env.ps1" }
if (Test-Path "$PSScriptRoot\aliases.ps1")   { . "$PSScriptRoot\aliases.ps1" }
if (Test-Path "$PSScriptRoot\functions.ps1") { . "$PSScriptRoot\functions.ps1" }
if (Test-Path "$PSScriptRoot\local.ps1")     { . "$PSScriptRoot\local.ps1" }

# ── Interactive shell setup (the .zshrc-equivalent layer) ──

# PSReadLine — zsh-like: emacs keys, inline autosuggestions, prefix history,
# menu completion on Tab.
Set-PSReadLineOption -EditMode Emacs
Set-PSReadLineOption -PredictionSource HistoryAndPlugin
Set-PSReadLineOption -PredictionViewStyle InlineView
Set-PSReadLineOption -HistorySearchCursorMovesToEnd
Set-PSReadLineKeyHandler -Key Tab       -Function MenuComplete
Set-PSReadLineKeyHandler -Key UpArrow   -Function HistorySearchBackward
Set-PSReadLineKeyHandler -Key DownArrow -Function HistorySearchForward

# PSFzf — your fzf keybindings: Ctrl+r history, Ctrl+t files, Alt+c cd.
# (Set after PSReadLine so fzf's Ctrl+r wins.)
if (Get-Module -ListAvailable PSFzf) {
  Import-Module PSFzf
  Set-PsFzfOption -PSReadlineChordProvider 'Ctrl+t' `
                  -PSReadlineChordReverseHistory 'Ctrl+r' `
                  -PSReadlineChordSetLocation 'Alt+c'
}

# mise — runtime version manager (node/python/bun/uv), same as Linux/Kamino.
# Activate so per-directory tool versions and shims resolve in interactive shells.
if (Get-Command mise -ErrorAction SilentlyContinue) {
  (& mise activate pwsh) | Out-String | Invoke-Expression
}

# Oh My Posh — same prompt as Linux, reusing the chezmoi-managed config.
if (Get-Command oh-my-posh -ErrorAction SilentlyContinue) {
  $ompCfg = "$HOME/.config/oh-my-posh/config.toml"
  if (Test-Path $ompCfg) {
    # Export the theme path so the prompt can still find the config if the
    # cache is cleared mid-session (`oh-my-posh print` reads the session theme
    # from the cache; without this it falls back to the default theme).
    $env:POSH_THEME = $ompCfg
    oh-my-posh init pwsh --config $ompCfg | Invoke-Expression
  }
  else { oh-my-posh init pwsh | Invoke-Expression }
}
