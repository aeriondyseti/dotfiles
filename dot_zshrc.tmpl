# ~/.zshrc: executed by zsh(1) for interactive shells.

# ─────────────────────────────────────────
# History
# ─────────────────────────────────────────
mkdir -p "${XDG_STATE_HOME:-$HOME/.local/state}/zsh"
HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
setopt APPEND_HISTORY
setopt EXTENDED_HISTORY
setopt HIST_VERIFY
setopt HIST_REDUCE_BLANKS

# ─────────────────────────────────────────
# Source config files (always — env / path / api-keys are needed
# even inside Claude Code's tool subshells)
# ─────────────────────────────────────────
[ -f "$HOME/.config/zsh/env.zsh" ] && source "$HOME/.config/zsh/env.zsh"
[ -f "$HOME/.config/zsh/path.zsh" ] && source "$HOME/.config/zsh/path.zsh"
[ -f "$HOME/.config/zsh/api-keys.zsh" ] && source "$HOME/.config/zsh/api-keys.zsh"

# ─────────────────────────────────────────
# Interactive UX — skipped inside Claude Code.
# Claude's Bash tool subshells inherit CLAUDECODE=1; sourcing oh-my-zsh,
# fzf, zoxide, and oh-my-posh there is wasted work and emits zle errors
# when there's no real TTY.
# init.zsh sources oh-my-zsh first; user aliases/functions come after
# so they override any plugin-defined conflicts.
# ─────────────────────────────────────────
if [[ -z "$CLAUDECODE" ]]; then
  [ -f "$HOME/.config/zsh/init.zsh" ] && source "$HOME/.config/zsh/init.zsh"
  [ -f "$HOME/.config/zsh/aliases.zsh" ] && source "$HOME/.config/zsh/aliases.zsh"
  [ -f "$HOME/.config/zsh/functions.zsh" ] && source "$HOME/.config/zsh/functions.zsh"
fi

# ─────────────────────────────────────────
# Local overrides (not checked in to chezmoi)
# ─────────────────────────────────────────
[ -f "$HOME/.config/zsh/local.zsh" ] && source "$HOME/.config/zsh/local.zsh"
