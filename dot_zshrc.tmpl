# ~/.zshrc: executed by zsh(1) for interactive shells.


# ─────────────────────────────────────────
# History
# ─────────────────────────────────────────
HISTSIZE=100000
SAVEHIST=100000
mkdir -p "${XDG_STATE_HOME:-$HOME/.local/state}/zsh"
HISTFILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh/history"
setopt SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_ALL_DUPS APPEND_HISTORY
setopt EXTENDED_HISTORY      # adds timestamps to history entries
setopt HIST_VERIFY           # !! and !$ pause before running, give a chance to edit
setopt HIST_REDUCE_BLANKS    # trim extraneous whitespace from history entries


# ─────────────────────────────────────────
# Oh My Zsh
# ─────────────────────────────────────────
{{- if eq .profile "personal" }}
[ -x /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
{{- end }}
mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
export ZSH_COMPDUMP="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-${HOST}-${ZSH_VERSION}"
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""
plugins=(
  aliases chezmoi colored-man-pages command-not-found dotenv extract
  fzf gh git gitignore ssh sudo
  zsh-autosuggestions zsh-syntax-highlighting
{{- if ne .profile "server" }}
  docker docker-compose mise uv 1password
{{- end }}
{{- if eq .profile "work" }}
  brew
{{- end }}
)
source "$ZSH/oh-my-zsh.sh"


# ─────────────────────────────────────────
# Source config files
# ─────────────────────────────────────────
[ -f ~/.config/zsh/env.zsh ]       && source ~/.config/zsh/env.zsh
[ -f ~/.config/zsh/path.zsh ]      && source ~/.config/zsh/path.zsh
[ -f ~/.config/zsh/aliases.zsh ]   && source ~/.config/zsh/aliases.zsh
[ -f ~/.config/zsh/functions.zsh ] && source ~/.config/zsh/functions.zsh
[ -f ~/.config/zsh/api-keys.zsh ]  && source ~/.config/zsh/api-keys.zsh


# ─────────────────────────────────────────
# Completions and key-bindings
# ─────────────────────────────────────────
{{- if or (eq .profile "work") (eq .profile "personal") }}
# fzf installed via Homebrew/Linuxbrew
[ -f "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh" ] && source "$(brew --prefix)/opt/fzf/shell/key-bindings.zsh"
[ -f "$(brew --prefix)/opt/fzf/shell/completion.zsh" ]   && source "$(brew --prefix)/opt/fzf/shell/completion.zsh"
{{- else }}
# Linux: fzf from apt/package manager
[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[ -f /usr/share/doc/fzf/examples/completion.zsh ]   && source /usr/share/doc/fzf/examples/completion.zsh
{{- end }}


# ─────────────────────────────────────────
# Final initializations
# ─────────────────────────────────────────
[[ -o interactive ]] && eval "$(zoxide init zsh)"
{{- if ne .profile "server" }}
# Gate: skip oh-my-posh inside Claude Code — its prompt rendering interferes
[[ -z "$CLAUDE_CODE" ]] && eval "$(oh-my-posh init zsh --config "$HOME/.config/oh-my-posh/config.toml")"
{{- end }}



# ─────────────────────────────────────────
# Local overrides (not checked in)
# ─────────────────────────────────────────
[ -f ~/.config/zsh/local.zsh ] && source ~/.config/zsh/local.zsh
