# ~/.zprofile: executed at login (once), not on every interactive shell.

# ─────────────────────────────────────────
# XDG Base Directories
# ─────────────────────────────────────────
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

# Ensure they exist
mkdir -p "$XDG_CONFIG_HOME" "$XDG_DATA_HOME" "$XDG_CACHE_HOME" "$XDG_STATE_HOME"

# ─────────────────────────────────────────
# Locale
# ─────────────────────────────────────────
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# Environment + PATH (also sourced from .zshrc for non-login interactive shells).
# Sourcing here ensures GUI launches (login shells without .zshrc) inherit
# the correct environment.
[ -f "$HOME/.config/zsh/env.zsh" ] && source "$HOME/.config/zsh/env.zsh"
[ -f "$HOME/.config/zsh/path.zsh" ] && source "$HOME/.config/zsh/path.zsh"
