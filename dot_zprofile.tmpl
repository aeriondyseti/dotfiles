# ~/.zprofile: executed at login (once), not on every interactive shell.

# ─────────────────────────────────────────
# XDG Base Directories
# ─────────────────────────────────────────
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_STATE_HOME="$HOME/.local/state"

# Ensure they exist
mkdir -p "$XDG_CONFIG_HOME" "$XDG_DATA_HOME" "$XDG_CACHE_HOME" "$XDG_STATE_HOME"

# ─────────────────────────────────────────
# Locale
# ─────────────────────────────────────────
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# ─────────────────────────────────────────
# Environment (also sourced from .zshrc for interactive shells)
# ─────────────────────────────────────────
[ -f "$HOME/.config/zsh/env.zsh" ] && source "$HOME/.config/zsh/env.zsh"

# ─────────────────────────────────────────
# PATH
# Brew shellenv stays here (sets MANPATH/INFOPATH/HOMEBREW_PREFIX too).
# Everything else lives in ~/.config/zsh/path.zsh — single source of truth.
# ─────────────────────────────────────────
{{- if eq .profile "work" }}
eval "$(/opt/homebrew/bin/brew shellenv zsh)"
{{- else if eq .profile "personal" }}
[ -x /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"
{{- end }}
[ -f "$HOME/.config/zsh/path.zsh" ] && source "$HOME/.config/zsh/path.zsh"
