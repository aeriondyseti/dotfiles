{{- if eq .profile "windows" -}}
# Install core CLI tools on Windows — managed by chezmoi.
# Parallels run_once_before_install-packages.sh (brew) for Unix.
# Renders empty on non-windows profiles so chezmoi skips it.
$ErrorActionPreference = 'Stop'

$pkgs = @(
  'eza-community.eza',        # ls
  'sharkdp.bat',             # cat
  'sharkdp.fd',              # find
  'BurntSushi.ripgrep.MSVC', # grep
  'ajeetdsouza.zoxide',      # cd/z
  'Clement.bottom',          # top (btm)  — btop has no Windows build
  'junegunn.fzf',            # fuzzy finder (used by PSFzf)
  'JanDeDobbeleer.OhMyPosh', # prompt (same config as Linux)
  'dbrgn.tealdeer',          # tldr — man-page replacement
  'dandavison.delta',        # git pager (referenced in git config)
  'GitHub.cli'               # gh — git credential helper
)

foreach ($p in $pkgs) {
  winget list --id $p -e --accept-source-agreements *> $null
  if ($LASTEXITCODE -ne 0) {
    Write-Host "Installing $p ..."
    winget install --id $p -e --source winget `
      --accept-package-agreements --accept-source-agreements
  } else {
    Write-Host "$p already installed"
  }
}

# PSFzf is a PowerShell module (not on winget) — gives Ctrl+r/Ctrl+t/Alt+c.
if (-not (Get-Module -ListAvailable PSFzf)) {
  Write-Host "Installing PSFzf module ..."
  Install-Module PSFzf -Scope CurrentUser -Force -AcceptLicense
}

# Refresh tldr's page cache so 'tldr <cmd>' works immediately.
if (Get-Command tldr -ErrorAction SilentlyContinue) { tldr --update 2>$null }

Write-Host "Done. Set a Nerd Font in your terminal for eza --icons / Oh My Posh glyphs."
{{- end -}}
