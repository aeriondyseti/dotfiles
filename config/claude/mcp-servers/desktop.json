{
  "mcpServers": {
    "vector-memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@aeriondyseti/vector-memory-mcp@alpha"],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--mode",
        "no-memories",
        "--mode",
        "no-onboarding",
        "--context",
        "claude-code",
        "--project",
        "<REPLACE_WITH_PROJECT_DIR>"
      ],
      "env": {}
    }
  }
}
