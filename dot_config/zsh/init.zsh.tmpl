# ─────────────────────────────────────────
# Interactive Shell Experience (Plugins, Theme, & Integrations)
# Sourced from .zshrc only when CLAUDECODE is unset.
# ─────────────────────────────────────────

# Initialize Homebrew environment early so fzf/zoxide/etc are in PATH
if [[ -f "/opt/homebrew/bin/brew" ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -f "/home/linuxbrew/.linuxbrew/bin/brew" ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Cache the brew prefix to avoid repeat `brew --prefix` calls.
# Empty if no brew installation is found (server profile path).
BREW_PREFIX=""
if [[ -n "${HOMEBREW_PREFIX:-}" ]]; then
  BREW_PREFIX="$HOMEBREW_PREFIX"
elif command -v brew >/dev/null; then
  BREW_PREFIX="$(brew --prefix)"
fi

# Zsh internals
mkdir -p "${XDG_CACHE_HOME:-$HOME/.cache}/zsh"
export ZSH_COMPDUMP="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-${HOST}-${ZSH_VERSION}"
export ZSH="$HOME/.oh-my-zsh"

# Oh My Zsh Configuration
ZSH_THEME="" # Handled by Oh My Posh below
plugins=(
  aliases chezmoi colored-man-pages command-not-found dotenv extract
  fzf gh git gitignore ssh sudo
  zsh-autosuggestions zsh-syntax-highlighting
{{- if ne .profile "server" }}
  docker docker-compose mise uv 1password
  brew
{{- end }}
)
source "$ZSH/oh-my-zsh.sh"

# ─────────────────────────────────────────
# Tool Integrations
# ─────────────────────────────────────────

# fzf: Completion & Key Bindings (brew location preferred; apt fallback for server)
if [[ -n "$BREW_PREFIX" && -d "$BREW_PREFIX/opt/fzf/shell" ]]; then
  source "$BREW_PREFIX/opt/fzf/shell/key-bindings.zsh"
  source "$BREW_PREFIX/opt/fzf/shell/completion.zsh"
elif [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]]; then
  source /usr/share/doc/fzf/examples/key-bindings.zsh
  [ -f /usr/share/doc/fzf/examples/completion.zsh ] && source /usr/share/doc/fzf/examples/completion.zsh
fi

# Zoxide (Smart 'cd')
# zle gate: protects against interactive-but-no-tty contexts (e.g.
# `zsh -i -c '...'`) where zoxide's widget setup would emit
# "(eval):1: can't change option: zle" errors.
if command -v zoxide >/dev/null && [[ -o interactive && -o zle ]]; then
  eval "$(zoxide init zsh)"
fi

{{- if ne .profile "server" }}

# Oh My Posh (Prompt Theme)
if command -v oh-my-posh >/dev/null; then
  eval "$(oh-my-posh init zsh --config "$HOME/.config/oh-my-posh/config.toml")"
fi
{{- end }}
