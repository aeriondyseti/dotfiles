# ─────────────────────────────────────────
# Kubernetes
# ─────────────────────────────────────────

update-kubecfg() {
    CONFIG=${1:-config}
    kubeconfigfiles=(~/.kube/configs/*.${CONFIG})
    local IFS=:
    export KUBECONFIG=$(echo "${kubeconfigfiles[*]}")
    unset IFS
    kubectl config view --raw=true > ~/.kube/configs/combined.cfg
}

fetch-s3-kubecfg() {
    aws sso login --profile devops-build-staff
    aws s3 cp s3://favor-eks-kubeconfigs/ ~/.kube/configs --recursive --profile devops-build-staff
}

fetch-kubecfg() {
    kubecfg_string="kubecfg-$1"

    mkdir -p ~/.kube/configs

    if ! command -v op &>/dev/null; then
        echo "Please ensure you have the 1pass CLI installed."
        echo "See https://favorengineering.atlassian.net/wiki/spaces/DE/pages/3897196572/1password+CLI for instructions"
        return 1
    fi

    op account list | grep favor &> /dev/null
    if [ $? -ne 0 ]; then
        echo "1pass CLI does not appear to have been configured."
        echo "See https://favorengineering.atlassian.net/wiki/spaces/DE/pages/3897196572/1password+CLI for instructions"
        return 1
    fi

    op whoami &> /dev/null || eval $(op signin --account favor)

    for config in $(op document list --vault="Engineering Shared" --format json | jq -r --arg kubecfg_string ${kubecfg_string} '.[] | select( .title | contains($kubecfg_string) ) | .title' ); do
        echo "fetching ${config}"
        op document get "${config}" --vault="Engineering Shared" > ~/.kube/configs/$(echo ${config} | sed 's/kubecfg-//').config
    done

    fetch-s3-kubecfg

    update-kubecfg
}
