# ─────────────────────────────────────────
# Claude helpers
# ─────────────────────────────────────────
#
# Convention: `c`/`cc` (and `cpers`/`ccpers` on work) are functions so the
# `/color` slash command lands AFTER user args. The `!`-variants are
# aliases that add `--dangerously-skip-permissions` — canonical daily form.
# `chelp` adds the helper-prompt-generated system prompt.

ask-claude() {
    : "Ask claude a single question without entering the TUI (read-only tools)."
    if [ -z "$*" ]; then
        echo "Usage: ask-claude '<question>'" >&2
        return 1
    fi
{{- if eq .profile "work" }}
    CLAUDE_CONFIG_DIR=~/.claude-work \claude -p "$*" \
        --allowedTools "Read,Grep,Glob" \
        --disallowedTools "Write,Edit,Bash"
{{- else if eq .profile "personal" }}
    \claude -p "$*" \
        --allowedTools "Read,Grep,Glob" \
        --disallowedTools "Write,Edit,Bash"
{{- end }}
}
alias ask='ask-claude'

{{- if eq .profile "work" }}

# Work machine has dual claude profiles. Default ~/.claude-work (blue);
# cpers/ccpers (and !-variants) target ~/.claude-personal (orange).

c() {
    : "Spawn claude with the work profile (~/.claude-work, blue prompt)."
    CLAUDE_CONFIG_DIR=~/.claude-work \claude "$@" /color blue
}
cc() { c --continue "$@"; }

cpers() {
    : "Spawn claude with the personal profile (~/.claude-personal, orange prompt)."
    CLAUDE_CONFIG_DIR=~/.claude-personal \claude "$@" /color orange
}
ccpers() { cpers --continue "$@"; }

alias 'c!'='c --dangerously-skip-permissions'
alias 'cc!'='cc --dangerously-skip-permissions'
alias 'cpers!'='cpers --dangerously-skip-permissions'
alias 'ccpers!'='ccpers --dangerously-skip-permissions'

chelp() {
    : "Spawn claude with the helper system prompt (work profile, blue)."
    CLAUDE_CONFIG_DIR=~/.claude-work \claude --system-prompt-file <(helper-prompt) "$@" /color blue
}
alias 'chelp!'='chelp --dangerously-skip-permissions'

{{- else if eq .profile "personal" }}

# Personal machine: single claude profile (~/.claude, orange).

c() {
    : "Spawn claude (single profile, orange prompt)."
    \claude "$@" /color orange
}
cc() { c --continue "$@"; }

alias 'c!'='c --dangerously-skip-permissions'
alias 'cc!'='cc --dangerously-skip-permissions'

chelp() {
    : "Spawn claude with the helper system prompt loaded."
    \claude --system-prompt-file <(helper-prompt) "$@" /color orange
}
alias 'chelp!'='chelp --dangerously-skip-permissions'

{{- end }}

# ─────────────────────────────────────────
# Fuzzy stuff (fzf)
# ─────────────────────────────────────────

fkillProc() {
    : "Fuzzy-pick a process and kill it. Use --force/-f for SIGKILL."
    local pid sig=15

    if [[ "$1" == "--force" || "$1" == "-f" ]]; then
        sig=9
        shift
    fi

    pid=$(ps aux | fzf --header-lines=1 --preview 'echo {}' | awk '{print $2}')
    [ -n "$pid" ] && kill -"$sig" "$pid" && echo "Killed $pid (SIG$([ $sig -eq 9 ] && echo KILL || echo TERM))"
}
alias fkill='fkillProc'

fkillport() {
    : "Fuzzy-pick a listening port's owner and kill it. --root for sudo, --force for SIGKILL."
    local selection pid sudo_cmd="" sig=15

    for arg in "$@"; do
        case "$arg" in
            --root|-r)  sudo_cmd="sudo" ;;
            --force|-f) sig=9 ;;
            *) echo "Usage: fkillport [--root|-r] [--force|-f]"; return 1 ;;
        esac
    done

    if [[ -n "$sudo_cmd" ]]; then
        if ! sudo -v; then
            echo "Error: sudo authentication failed."
            return 1
        fi
    fi
{{- if eq .profile "work" }}
    selection=$( $sudo_cmd lsof -iTCP -sTCP:LISTEN -P -n | fzf --header-lines=1 --prompt="Kill Port> " --preview 'echo {}' )

    if [[ -n "$selection" ]]; then
        pid=$(echo "$selection" | awk '{print $2}')
{{- else }}
    selection=$( $sudo_cmd ss -tulnp | fzf --header-lines=1 --prompt="Kill Port> " --preview 'echo {}' )

    if [[ -n "$selection" ]]; then
        pid=$(echo "$selection" | grep -oP 'pid=\K[0-9]+' | head -1)
{{- end }}

        if [[ -n "$pid" ]]; then
            $sudo_cmd kill -"$sig" "$pid" && echo "Sent SIG$([ $sig -eq 9 ] && echo KILL || echo TERM) to PID $pid"
        else
            echo "Error: No PID found in selection."
            [[ -z "$sudo_cmd" ]] && echo "(Try running with --root if it's a system process)"
        fi
    fi
}
alias fkp='fkillport'

# ─────────────────────────────────────────
# Taskwarrior
# ─────────────────────────────────────────

tp() {
    : "Fuzzy-pick a pending Taskwarrior task; print its ID."
    task export status:pending 2>/dev/null \
      | jq -r '.[] | "\(.id)\t[\(.project // "-")]\t\(.description)"' \
      | fzf --preview 'task {1} info' \
      | awk '{print $1}'
}

tlist() {
    : "Fuzzy-pick any Taskwarrior task (all statuses); print its ID."
    task export 2>/dev/null \
      | jq -r '.[] | "\(.id)\t[\(.project // "-")]\t\(.description)"' \
      | fzf --preview 'task {1} info' \
      | awk '{print $1}'
}

# ─────────────────────────────────────────
# fa — fuzzy-find aliases and functions
# ─────────────────────────────────────────

fa() {
    : "Fuzzy-find aliases and functions, with descriptions and previews."
    local selection name
    selection=$(
        {
            # Aliases: name=expansion
            alias | sed -E 's/^/alias: /'
            # Functions: name + docstring (first `: "..."` in body) if present
            for fn in ${(k)functions}; do
                local doc
                doc=$(functions "$fn" | grep -m1 -oE ':[[:space:]]+"[^"]+"' | sed -E 's/^:[[:space:]]+"//; s/"$//')
                if [[ -n "$doc" ]]; then
                    printf "func:  %s  —  %s\n" "$fn" "$doc"
                else
                    printf "func:  %s\n" "$fn"
                fi
            done
        } | sort -u | fzf \
            --preview 'name=$(echo {} | sed -E "s/^(alias|func): +//" | cut -d= -f1 | awk "{print \$1}");
                       if alias "$name" >/dev/null 2>&1; then
                         echo "ALIAS: $name"
                         alias "$name" | cut -d= -f2-
                       else
                         echo "FUNCTION: $name"
                         echo
                         functions "$name"
                       fi' \
            --preview-window=down:15
    )
    [[ -z "$selection" ]] && return
    name=$(echo "$selection" | sed -E 's/^(alias|func): +//' | cut -d= -f1 | awk '{print $1}')
    echo "$name"
}

# Optional: Alt-A widget to insert the picked name at the prompt
fa-widget() {
    local sel
    sel=$(fa)
    LBUFFER+="$sel"
    zle reset-prompt
}
zle -N fa-widget
bindkey '^[a' fa-widget

