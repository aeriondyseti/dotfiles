# cd into ~/Development/<dir> with tab completion
dev() {
{{- if eq .profile "work" }}
    builtin cd "$HOME/Development/$1"
{{- else }}
    builtin cd "$HOME/Personal/Development/$1"
{{- end }}
}
_dev() {
    ((CURRENT == 2)) &&
{{- if eq .profile "work" }}
    _files -/ -W "$HOME/Development"
{{- else }}
    _files -/ -W "$HOME/Personal/Development"
{{- end }}
}
# compdef is provided by oh-my-zsh's compinit; skipped under Claude Code
(( ${+functions[compdef]} )) && compdef _dev dev

