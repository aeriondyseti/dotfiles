# Environment — managed by chezmoi

# ─────────────────────────────────────────
# Editors
# ─────────────────────────────────────────
export EDITOR='{{ .editor }}'
export VISUAL='{{ .visual }}'

# ─────────────────────────────────────────
# Pagers
# ─────────────────────────────────────────
export PAGER='less'
export LESS='-R -F -X'
export MANROFFOPT='-c'
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
{{- if ne .profile "work" }}
export SYSTEMD_LESS="$LESS"
{{- end }}

# ─────────────────────────────────────────
# bat
# ─────────────────────────────────────────
export BAT_THEME='ansi'

# ─────────────────────────────────────────
# FZF
# ─────────────────────────────────────────
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --inline-info'

# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
export PYTHONDONTWRITEBYTECODE=1
export PYTHONUNBUFFERED=1

{{- if ne .profile "server" }}

# ─────────────────────────────────────────
# Huggingface
# ─────────────────────────────────────────
export HF_HUB_ENABLE_HF_TRANSFER=1
{{- end }}

{{- if ne .profile "work" }}

# ─────────────────────────────────────────
# Linux-only
# ─────────────────────────────────────────
export BROWSER='xdg-open'
{{- end }}

# ─────────────────────────────────────────
# Gemini CLI defaults
# ─────────────────────────────────────────
export GEMINI_TOOL_PRESET=text
export GEMINI_ENABLED_TOOLS=image-gen,image-edit,image-analyze

# ─────────────────────────────────────────
# XDG redirects for tools that hard-code $HOME paths
# (keeps ~ navigable; cf. ~/.claude/plans/i-want-to-clean-tender-journal.md §3)
# ─────────────────────────────────────────

# npm
export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npm/npmrc"
export NPM_CONFIG_CACHE="$XDG_CACHE_HOME/npm"

# Taskwarrior
export TASKRC="$XDG_CONFIG_HOME/task/taskrc"
export TASKDATA="$XDG_DATA_HOME/task"

# GTK 2
export GTK2_RC_FILES="$XDG_CONFIG_HOME/gtk-2.0/gtkrc"

# Rust
export CARGO_HOME="$XDG_DATA_HOME/cargo"
export RUSTUP_HOME="$XDG_DATA_HOME/rustup"

# Bun
export BUN_INSTALL="$XDG_DATA_HOME/bun"

# Docker
export DOCKER_CONFIG="$XDG_CONFIG_HOME/docker"

# GnuPG
export GNUPGHOME="$XDG_DATA_HOME/gnupg"

# .NET
export DOTNET_CLI_HOME="$XDG_DATA_HOME/dotnet"

# Hugging Face
export HF_HOME="$XDG_CACHE_HOME/huggingface"

# Ollama
export OLLAMA_MODELS="$XDG_DATA_HOME/ollama/models"

# CUDA / NVIDIA shader caches
export CUDA_CACHE_PATH="$XDG_CACHE_HOME/nv"
export __GL_SHADER_DISK_CACHE_PATH="$XDG_CACHE_HOME/nv"

# wget HSTS file (also referenced by ~/.config/wgetrc)
export WGETRC="$XDG_CONFIG_HOME/wgetrc"
